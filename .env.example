# قاعدة بيانات PostgreSQL للإنتاج أو Vercel Postgres / Neon / Supabase
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# مفتاح سري لتوقيع جلسات الدخول — غيّره إلى قيمة عشوائية طويلة
AUTH_SECRET="change-this-to-a-long-random-secret-string-please-32chars+"

# بيانات الحساب الثابت الأولي (يُنشأ عند تشغيل seed)
SEED_EMAIL="test@test.com"
SEED_PASSWORD="test1234"
